<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Dedicated log channel: var/log/meilisearch_chat.log -->
    <virtualType name="Walkwizus\MeilisearchChatBase\Logger\Handler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/meilisearch_chat.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="Walkwizus\MeilisearchChatBase\Logger\Logger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">meilisearch_chat</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Walkwizus\MeilisearchChatBase\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Walkwizus\MeilisearchChatBase\Service\ChatLogger">
        <arguments>
            <argument name="logger" xsi:type="object">Walkwizus\MeilisearchChatBase\Logger\Logger</argument>
        </arguments>
    </type>
</config>
