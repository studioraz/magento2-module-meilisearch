<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="catalogProductMeilisearchIndexHandler" type="Walkwizus\MeilisearchBase\Model\Indexer\BaseIndexerHandler">
        <arguments>
            <argument name="indexerId" xsi:type="string">catalog_product</argument>
            <argument name="indexPrimaryKey" xsi:type="string">id</argument>
            <argument name="preProcessors" xsi:type="array">
                <item name="catalog_product" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\Indexer\PreProcessor\CatalogProduct\UrlKey</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Walkwizus\MeilisearchCatalog\Model\Indexer\CompositeIndexerHandler">
        <arguments>
            <argument name="mirrorIndexerHandler" xsi:type="object">catalogProductMeilisearchIndexHandler</argument>
        </arguments>
    </type>
    <type name="Magento\CatalogSearch\Model\Indexer\IndexerHandlerFactory">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="opensearch" xsi:type="string">Walkwizus\MeilisearchCatalog\Model\Indexer\CompositeIndexerHandler</item>
            </argument>
        </arguments>
    </type>
    <type name="Walkwizus\MeilisearchBase\Model\AttributeProvider">
        <arguments>
            <argument name="providers" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="index" xsi:type="array">
                        <item name="categoryPosition" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeProvider\CatalogProduct\CategoryPosition</item>
                        <item name="eav" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeProvider\CatalogProduct\Eav</item>
                        <item name="price" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeProvider\CatalogProduct\Price</item>
                    </item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Walkwizus\MeilisearchBase\Model\AttributeMapper">
        <arguments>
            <argument name="mappers" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="category" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeMapper\CatalogProduct\Category</item>
                    <item name="eav" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeMapper\CatalogProduct\Eav</item>
                    <item name="image" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeMapper\CatalogProduct\Image</item>
                    <item name="inventory" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeMapper\CatalogProduct\Inventory</item>
                    <item name="price" xsi:type="object">Walkwizus\MeilisearchCatalog\Model\AttributeMapper\CatalogProduct\Price</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
