<script>
    function initMeilisearchChat() {
        return {
            config: {},
            messages: [],
            draft: '',
            loading: false,
            searching: false,
            error: '',
            panelOpen: false,
            controller: null,
            storageKey: 'meilisearch_chat',
            defaultError: '<?= $escaper->escapeJs(__('Something went wrong. Please try again.')) ?>',

            init() {
                this.config = JSON.parse(this.$root.dataset.config || '{}');
                this.restore();
                if (this.messages.length === 0 && this.config.welcomeMessage) {
                    this.messages.push(this.assistantMessage(this.config.welcomeMessage, true));
                }
                if (this.panelOpen) {
                    this.$nextTick(() => this.trap());
                }
            },

            assistantMessage(content, seed) {
                return {role: 'assistant', content: content, isUser: false, isAssistant: true, seed: !!seed, cards: [], hasCards: false};
            },

            updateDraft() {
                this.draft = this.$event.target.value;
            },

            togglePanel() {
                this.panelOpen ? this.closePanel() : this.openPanel();
            },

            openPanel() {
                this.panelOpen = true;
                this.persist();
                this.$nextTick(() => {
                    this.trap();
                    this.scrollToBottom();
                    if (this.$refs.input) this.$refs.input.focus();
                });
            },

            closePanel() {
                if (!this.panelOpen) {
                    return;
                }
                this.panelOpen = false;
                this.release();
                this.persist();
            },


            resetChat() {
                if (this.controller) {
                    this.controller.abort();
                    this.controller = null;
                }
                this.loading = false;
                this.searching = false;
                this.error = '';
                this.draft = '';
                this.messages = [];
                try {
                    window.sessionStorage.removeItem(this.storageKey);
                } catch (e) {}
                if (this.config.welcomeMessage) {
                    this.messages.push(this.assistantMessage(this.config.welcomeMessage, true));
                }
                this.persist();
                this.scrollToBottom();
                this.$nextTick(() => { if (this.$refs.input) this.$refs.input.focus(); });
            },

            trap() {
                if (window.hyva && hyva.trapFocus && this.$refs.panel) {
                    hyva.trapFocus(this.$refs.panel);
                }
            },

            release() {
                if (window.hyva && hyva.releaseFocus && this.$refs.panel) {
                    hyva.releaseFocus(this.$refs.panel);
                }
            },

            async send() {
                const text = this.draft.trim();
                if (!text || this.loading) {
                    return;
                }
                this.error = '';
                this.draft = '';
                this.messages.push({role: 'user', content: text, isUser: true, isAssistant: false, cards: [], hasCards: false});
                this.messages.push(this.assistantMessage('', false));
                const ai = this.messages[this.messages.length - 1];
                this.loading = true;
                this.searching = true;
                this.persist();
                this.scrollToBottom();

                const history = this.messages
                    .filter(m => !m.seed && (m.isUser || m.content !== ''))
                    .map(m => ({role: m.role, content: m.content}));

                this.controller = new AbortController();
                try {
                    const resp = await fetch(this.config.completionsUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                            'X-Magento-Form-Key': hyva.getFormKey()
                        },
                        body: JSON.stringify({messages: history}),
                        signal: this.controller.signal
                    });

                    if (!resp.ok || !resp.body) {
                        let message = this.defaultError;
                        try {
                            const data = await resp.json();
                            if (data && data.error) {
                                message = data.error;
                            }
                        } catch (e) {}
                        throw new Error(message);
                    }

                    await this.readStream(resp.body, ai);
                    // Stream finished ([DONE]): now reveal any buffered product cards, so they
                    // appear only after the message has fully streamed in.
                    ai.hasCards = ai.cards.length > 0;
                } catch (e) {
                    if (e.name !== 'AbortError') {
                        this.error = e.message || this.defaultError;
                    }
                } finally {
                    this.loading = false;
                    this.searching = false;
                    this.controller = null;
                    this.persist();
                    this.scrollToBottom();
                }
            },

            async readStream(body, ai) {
                const reader = body.getReader();
                const decoder = new TextDecoder();
                let buffer = '';
                let event = 'message';
                let deltaBuffer = '';
                let rafScheduled = false;

                const flushBuffer = () => {
                    if (deltaBuffer) {
                        ai.content += deltaBuffer;
                        deltaBuffer = '';
                        this.scrollToBottom();
                    }
                    rafScheduled = false;
                };

                while (true) {
                    const {done, value} = await reader.read();
                    if (done) {
                        flushBuffer();
                        break;
                    }
                    buffer += decoder.decode(value, {stream: true});

                    let idx;
                    while ((idx = buffer.indexOf('\n')) >= 0) {
                        const line = buffer.slice(0, idx).replace(/\r$/, '');
                        buffer = buffer.slice(idx + 1);

                        if (line === '') {
                            event = 'message';
                            continue;
                        }
                        if (line.indexOf('event:') === 0) {
                            event = line.slice(6).trim();
                            continue;
                        }
                        if (line.indexOf('data:') === 0) {
                            const data = line.slice(5).trim();
                            if (data === '[DONE]') {
                                flushBuffer();
                                return;
                            }
                            if (event === 'message') {
                                this.searching = false;
                                try {
                                    const parsed = JSON.parse(data);
                                    const delta = parsed.choices?.[0]?.delta?.content ?? '';
                                    if (delta) {
                                        deltaBuffer += delta;
                                        if (!rafScheduled) {
                                            rafScheduled = true;
                                            requestAnimationFrame(flushBuffer);
                                        }
                                    }
                                } catch (e) {}
                            } else {
                                this.handleEvent(event, data, ai);
                            }
                        }
                    }
                }
            },

            handleEvent(event, data, ai) {
                if (event === 'products') {
                    try {
                        const parsed = JSON.parse(data);
                        // Buffer the cards but do NOT reveal them yet: _meiliSearchSources arrives
                        // before the text answer, so we wait until streaming completes (see send()).
                        ai.cards = (parsed.products || []).map(this.decorateCard);
                    } catch (e) {}
                    return;
                }
                if (event === 'status') {
                    this.searching = true;
                    return;
                }
                if (event === 'error') {
                    try {
                        const parsed = JSON.parse(data);
                        this.error = parsed.message || this.defaultError;
                    } catch (e) {
                        this.error = this.defaultError;
                    }
                    return;
                }
                if (event === 'meta') {
                    return;
                }
            },

            renderContent(text) {
                const escaped = text
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;');
                return escaped.replace(/\*\*(.+?)\*\*/gs, '<b>$1</b>');
            },

            decorateCard(card) {
                const canAdd = !!(card.in_stock && card.id);
                return Object.assign({}, card, {canAddToCart: canAdd, viewOnly: !canAdd && !!card.url});
            },

            async addToCart() {
                const card = this.card;
                if (!card || !card.id) {
                    return;
                }
                try {
                    const fd = new FormData();
                    fd.append('product', card.id);
                    fd.append('qty', '1');
                    fd.append('form_key', hyva.getFormKey());
                    fd.append('uenc', hyva.getUenc());
                    await fetch(this.config.addToCartUrl, {
                        method: 'POST',
                        body: fd,
                        headers: {'X-Requested-With': 'XMLHttpRequest'}
                    });
                    window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                } catch (e) {
                    this.error = this.defaultError;
                }
            },

            scrollToBottom() {
                this.$nextTick(() => {
                    const el = this.$refs.messages;
                    if (el) {
                        el.scrollTo({ top: el.scrollHeight, behavior: 'instant' });
                    }
                });
            },


            persist() {
                try {
                    window.sessionStorage.setItem(this.storageKey, JSON.stringify({
                        messages: this.messages
                    }));
                } catch (e) {}
            },

            restore() {
                try {
                    const raw = window.sessionStorage.getItem(this.storageKey);
                    if (raw) {
                        const data = JSON.parse(raw);
                        const messages = Array.isArray(data.messages) ? data.messages : [];
                        this.messages = messages.map(m => {
                            const cards = Array.isArray(m.cards) ? m.cards : [];
                            return Object.assign({cards: cards}, m, {hasCards: cards.length > 0});
                        });
                    }
                } catch (e) {}
            }
        };
    }

    window.addEventListener('alpine:init', () => Alpine.data('initMeilisearchChat', initMeilisearchChat), {once: true});
</script>
<?php $hyvaCsp->registerInlineScript(); ?>
